# Database connection (PostgreSQL with asyncpg)
DATABASE_URL=postgresql+asyncpg://user:password@host:5432/auction_db
DIRECT_URL=postgresql+asyncpg://user:password@host:5432/auction_db

# JWT Authentication (CHANGE THIS IN PRODUCTION!)
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d
JWT_ALGORITHM=HS256

# Server
PORT=5000

# Frontend URL (for CORS)
FRONTEND_URL=https://your-frontend.vercel.app
